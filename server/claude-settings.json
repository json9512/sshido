{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "[ -z \"$SSHIDO_SESSION\" ] || ~/.local/bin/sshido-notify -p high 'Claude needs input' 'Check your session'" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "[ -z \"$SSHIDO_SESSION\" ] || ~/.local/bin/sshido-notify 'Task complete' 'Claude finished'" }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "[ -z \"$SSHIDO_SESSION\" ] || ~/.local/bin/sshido-notify -p high 'Claude error' 'Claude stopped with an error'" }
        ]
      }
    ]
  }
}
