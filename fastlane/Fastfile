default_platform(:ios)

WORKSPACE_PROJECT = "XcodeProject/sshido.xcodeproj"
SCHEME = "sshido"
IPA_PATH = "build/ipa/sshido.ipa"

platform :ios do
  desc "Bump build number"
  lane :bump do
    sh("cd .. && make bump")
  end

  desc "Archive Release + export IPA (reuses scripts/archive.sh)"
  lane :archive do
    sh("cd .. && make archive")
  end

  desc "Bump + archive + upload to TestFlight"
  lane :beta do
    sh("cd .. && make bump")
    sh("cd .. && make archive")
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false
    )
    upload_to_testflight(
      api_key: api_key,
      ipa: IPA_PATH,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload existing IPA to TestFlight (no bump/archive)"
  lane :upload do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false
    )
    upload_to_testflight(
      api_key: api_key,
      ipa: IPA_PATH,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Install to tethered device (Debug)"
  lane :device do
    sh("cd .. && make run")
  end
end
